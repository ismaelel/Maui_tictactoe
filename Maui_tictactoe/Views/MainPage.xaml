<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Maui_tictactoe.ViewModels"
             x:Class="Maui_tictactoe.MainPage">

    <VerticalStackLayout Padding="30" Spacing="25" HorizontalOptions="Center" VerticalOptions="Center">

        <Label Text="{Binding StatutTexte}"
               FontSize="24"
               FontAttributes="Bold"
               HorizontalOptions="Center" />

        <HorizontalStackLayout HorizontalOptions="Center" Spacing="20" Margin="0, 0, 0, 20">
            <Label Text="{Binding VictoiresUI, StringFormat='Victoires : {0}'}" TextColor="Green" FontAttributes="Bold" FontSize="18" />
            <Label Text="{Binding DefaitesUI, StringFormat='Défaites : {0}'}" TextColor="Red" FontAttributes="Bold" FontSize="18" />
            <Label Text="{Binding NulsUI, StringFormat='Nuls : {0}'}" TextColor="Gray" FontAttributes="Bold" FontSize="18" />
        </HorizontalStackLayout>

        <CollectionView ItemsSource="{Binding Cases}" HorizontalOptions="Center" WidthRequest="310">
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical" Span="3" VerticalItemSpacing="5" HorizontalItemSpacing="5" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Button FontSize="36" WidthRequest="100" HeightRequest="100"
                            Text="{Binding Symbole}" 
                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:JeuViewModel}}, Path=JouerCommand}" 
                            CommandParameter="{Binding .}" />
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Text="Rejouer"
                Command="{Binding RejouerCommand}"
                HorizontalOptions="Center"
                WidthRequest="200"
                Margin="0, 20, 0, 0"/>

    </VerticalStackLayout>
</ContentPage>