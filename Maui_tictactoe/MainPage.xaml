<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Maui_tictactoe.MainPage">

    <VerticalStackLayout Padding="30" Spacing="25" HorizontalOptions="Center" VerticalOptions="Center">

        <Label x:Name="StatutLabel"
               Text="Tour du joueur : X"
               FontSize="24"
               FontAttributes="Bold"
               HorizontalOptions="Center" />

        <Grid x:Name="GrilleMorpion"
              RowDefinitions="100, 100, 100"
              ColumnDefinitions="100, 100, 100"
              RowSpacing="5" ColumnSpacing="5"
              HorizontalOptions="Center">

            <Button Grid.Row="0" Grid.Column="0" FontSize="36" Clicked="OnCaseClicked" />
            <Button Grid.Row="0" Grid.Column="1" FontSize="36" Clicked="OnCaseClicked" />
            <Button Grid.Row="0" Grid.Column="2" FontSize="36" Clicked="OnCaseClicked" />

            <Button Grid.Row="1" Grid.Column="0" FontSize="36" Clicked="OnCaseClicked" />
            <Button Grid.Row="1" Grid.Column="1" FontSize="36" Clicked="OnCaseClicked" />
            <Button Grid.Row="1" Grid.Column="2" FontSize="36" Clicked="OnCaseClicked" />

            <Button Grid.Row="2" Grid.Column="0" FontSize="36" Clicked="OnCaseClicked" />
            <Button Grid.Row="2" Grid.Column="1" FontSize="36" Clicked="OnCaseClicked" />
            <Button Grid.Row="2" Grid.Column="2" FontSize="36" Clicked="OnCaseClicked" />
        </Grid>

        <Button Text="Rejouer"
                Clicked="OnRejouerClicked"
                HorizontalOptions="Center"
                WidthRequest="200"
                Margin="0, 20, 0, 0"/>

    </VerticalStackLayout>
</ContentPage>